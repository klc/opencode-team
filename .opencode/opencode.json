        "read": true,
        "webfetch": false,
        "websearch": false,
        "todowrite": true,
        "todoread": true
      },
      "permission": {
        "bash": {
          "*": "ask",
          "git status": "allow",
          "git diff *": "allow",
          "git log *": "allow",
          "git add *": "allow",
          "git commit *": "allow",
          "grep *": "allow",
          "find *": "allow",
          "cat *": "allow",
          "ls *": "allow",
          "git push": "deny",
          "git push *": "deny",
          "git rebase *": "deny",
          "git reset *": "deny",
          "rm -rf *": "deny",
          "sudo *": "deny"
        },
        "edit": "allow",
        "task": {
          "*": "deny"
        }
      },
      "color": "#a7f3d0"
    },
