          "git log *": "allow",
          "git add *": "allow",
          "git commit *": "allow",
          "grep *": "allow",
          "find *": "allow",
          "cat *": "allow",
          "ls *": "allow",
          "npm run *": "allow",
          "git push": "deny",
          "git push *": "deny",
          "git rebase *": "deny",
          "git reset *": "deny",
          "rm -rf *": "deny",
          "sudo *": "deny"
        },
        "edit": "allow",
        "task": {
          "*": "deny"
        }
      },
      "color": "#fed7aa"
    },
