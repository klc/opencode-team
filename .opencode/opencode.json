      "permission": {
        "bash": {
          "*": "allow",
          "git push": "ask",
          "git push *": "ask"
        },
        "task": {
          "*": "deny",
          "senior-frontend": "allow",
          "junior-frontend": "allow",
          "code-reviewer": "allow",
          "tester": "allow",
          "security-auditor": "allow",
          "seo-auditor": "allow",
          "performance-analyst": "allow",
          "debugger": "allow",
          "researcher": "allow",
          "librarian": "allow",
          "designer": "allow"
        }
      },
      "mode": "all",
      "color": "#fb923c"
    },
    "senior-backend": {
      "description": "Invoke for complex backend tasks: new architecture, integrations, performance-critical code, security flows. Reports completion to backend-lead via message — never updates Kanban.",
      "model": "my-provider/my-strong-model",
      "mode": "subagent",
      "hidden": true,
      "temperature": 0.2,
      "steps": 80,
      "tools": {
        "bash": true,
        "write": true,
        "edit": true,
        "read": true,
        "webfetch": true,
        "websearch": true,
        "todowrite": true,
        "todoread": true
      },
      "permission": {
        "bash": {
          "*": "allow",
          "git push": "ask",
          "git push *": "ask",
          "git rebase *": "ask",
          "git reset --hard *": "ask",
          "rm -rf *": "ask",
          "sudo *": "deny"
        },
        "edit": "allow",
        "task": {
          "*": "deny",
          "librarian": "allow"
        }
      },
      "color": "#6ee7b7"
    },
    "senior-frontend": {
      "description": "Invoke for complex frontend tasks: new pages, state management, SSR-sensitive code, complex components. Reports completion to frontend-lead via message — never updates Kanban.",
      "model": "my-provider/my-fast-model",
      "mode": "subagent",
      "hidden": true,
      "temperature": 0.3,
      "steps": 80,
      "tools": {
        "bash": true,
        "write": true,
        "edit": true,
        "read": true,
        "webfetch": true,
        "websearch": true,
        "todowrite": true,
        "todoread": true
      },
      "permission": {
        "bash": {
          "*": "allow",
          "git push": "ask",
          "git push *": "ask",
          "git rebase *": "ask",
          "git reset --hard *": "ask",
          "rm -rf *": "ask",
          "sudo *": "deny"
        },
        "edit": "allow",
        "task": {
          "*": "deny",
          "librarian": "allow"
        }
      },
      "color": "#fdba74"
    },
    "junior-backend": {
      "description": "Invoke for simple backend tasks: CRUD, adding fields, unit tests, isolated bug fixes. Reports completion to backend-lead via message — never updates Kanban.",
      "model": "my-provider/my-fast-model",
      "mode": "subagent",
      "hidden": true,
      "temperature": 0.3,
      "steps": 40,
      "tools": {
        "bash": true,
