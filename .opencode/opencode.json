{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "product-owner": {
      "description": "Invoke for new features or requirement changes. Clarifies scope, writes user stories, creates Kanban tasks, delegates to project-manager via Task tool. Never writes code.",
      "model": "my-provider/my-strong-model",
      "temperature": 0.5,
      "steps": 80,
      "tools": {
        "bash": false,
        "write": true,
        "edit": true,
        "read": true,
        "webfetch": false,
        "websearch": false
      },
      "permission": {
        "task": {
          "*": "deny",
          "project-manager": "allow",
          "architect": "allow",
          "librarian": "allow"
        }
      },
      "mode": "all",
      "color": "#a78bfa"
    },
    "project-manager": {
      "description": "Invoke after product-owner delivers a story. Creates Kanban subtasks, creates branch, assigns to leads via Task tool. Never writes code.",
      "model": "my-provider/my-strong-model",
      "temperature": 0.5,
      "steps": 80,
      "tools": {
        "bash": true,
        "write": true,
        "edit": true,
        "read": true,
        "webfetch": false,
        "websearch": false,
        "todowrite": true,
        "todoread": true
      },
      "permission": {
        "bash": {
          "*": "allow",
          "git push": "ask",
          "git push *": "ask"
        },
        "task": {
          "*": "deny",
          "backend-lead": "allow",
          "frontend-lead": "allow",
          "architect": "allow",
          "librarian": "allow"
        }
      },
      "mode": "all",
      "color": "#60a5fa"
    },
    "architect": {
      "description": "Invoke before major structural decisions: protocol/transport choice, new services, schema changes. Writes ADRs. Never writes production code.",
      "model": "my-provider/my-strong-model",
      "temperature": 0.4,
      "steps": 60,
      "tools": {
        "bash": false,
        "write": true,
        "edit": true,
        "read": true,
        "webfetch": true,
        "websearch": true
      },
      "permission": {
        "task": {
          "*": "deny",
          "researcher": "allow",
          "librarian": "allow"
        }
      },
      "mode": "all",
      "color": "#f472b6"
    },
    "backend-lead": {
      "description": "Invoke when backend tasks arrive from project-manager. Delegates to senior-backend (complex) or junior-backend (simple) via Task tool. Owns full delivery cycle: delegate → review → test → done.",
      "model": "my-provider/my-strong-model",
      "temperature": 0.3,
      "steps": 100,
      "tools": {
        "bash": true,
        "write": true,
        "edit": true,
        "read": true,
        "webfetch": true,
        "websearch": true,
        "todowrite": true,
        "todoread": true
      },
      "permission": {
        "bash": {
          "*": "allow",
          "git push": "ask",
          "git push *": "ask"
        },
        "task": {
          "*": "deny",
          "senior-backend": "allow",
          "junior-backend": "allow",
          "code-reviewer": "allow",
          "tester": "allow",
          "security-auditor": "allow",
          "performance-analyst": "allow",
          "debugger": "allow",
          "researcher": "allow",
          "librarian": "allow"
        }
      },
      "mode": "all",
      "color": "#34d399"
    },
    "frontend-lead": {
      "description": "Invoke when frontend tasks arrive from project-manager. Delegates to senior-frontend (complex) or junior-frontend (simple) via Task tool. Owns full delivery cycle: delegate → review → SEO audit → test → done.",
      "model": "my-provider/my-fast-model",
      "temperature": 0.4,
      "steps": 100,
      "tools": {
        "bash": true,
        "write": true,
        "edit": true,
        "read": true,
        "webfetch": true,
        "websearch": true,
