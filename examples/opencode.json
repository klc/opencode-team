{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "alibaba-coding-plan": {
      "name": "Alibaba Coding Plan",
      "npm": "@ai-sdk/anthropic",
      "api": "https://coding-intl.dashscope.aliyuncs.com/apps/anthropic/v1",
      "env": [
        "BAILIAN_CODING_PLAN_API_KEY"
      ],
      "models": {
        "qwen3.5-plus": {
          "name": "Qwen3.5 Plus",
          "reasoning": true,
          "tool_call": true,
          "modalities": {
            "input": [
              "text",
              "image",
              "video"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 1000000,
            "output": 65536
          },
          "cost": {
            "input": 0,
            "output": 0
          }
        },
        "glm-5": {
          "name": "GLM-5",
          "reasoning": true,
          "tool_call": true,
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 202752,
            "output": 16384
          },
          "cost": {
            "input": 0,
            "output": 0
          }
        },
        "kimi-k2.5": {
          "name": "Kimi K2.5",
          "reasoning": true,
          "tool_call": true,
          "modalities": {
            "input": [
              "text",
              "image",
              "video"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 262144,
            "output": 32768
          },
          "cost": {
            "input": 0,
            "output": 0
          }
        }
      }
    }
  },
  "agent": {
    "product-owner": {
      "description": "Invoke for new features or requirement changes. Clarifies scope, writes user stories, delegates to project-manager. Never writes code.",
      "model": "alibaba-coding-plan/qwen3.5-plus",
      "mode": "all",
      "steps": 80
    },
    "project-manager": {
      "description": "Invoke after product-owner delivers a story. Creates branch, breaks story into tasks, assigns to leads, maintains todo board. Never writes code.",
      "model": "alibaba-coding-plan/kimi-k2.5",
      "mode": "all",
      "steps": 80,
      "tools": {
        "todowrite": true,
        "todoread": true
      }
    },
    "architect": {
      "description": "Invoke before major structural decisions. Writes ADRs. Never writes production code.",
      "model": "alibaba-coding-plan/glm-5",
      "mode": "all",
      "steps": 60
    },
    "backend-lead": {
      "description": "Invoke when backend tasks arrive from project-manager. Delegates to developers. Triggers QA and review.",
      "model": "alibaba-coding-plan/glm-5",
      "mode": "all",
      "steps": 100,
      "tools": {
        "todowrite": true,
        "todoread": true
      }
    },
    "frontend-lead": {
      "description": "Invoke when frontend tasks arrive from project-manager. Delegates to developers. Triggers QA and review.",
      "model": "alibaba-coding-plan/kimi-k2.5",
      "mode": "all",
      "steps": 100,
      "tools": {
        "todowrite": true,
        "todoread": true
      }
    },
    "senior-backend": {
      "description": "Invoke for complex backend tasks: new architecture, integrations, performance-critical code.",
      "model": "alibaba-coding-plan/glm-5",
      "mode": "subagent",
      "steps": 80,
      "tools": {
        "todowrite": true,
        "todoread": true
      },
      "permission": {
        "bash": "allow",
        "edit": "allow"
      }
    },
    "senior-frontend": {
      "description": "Invoke for complex frontend tasks: new pages, state management, SSR-sensitive code.",
      "model": "alibaba-coding-plan/kimi-k2.5",
      "mode": "subagent",
      "steps": 80,
      "tools": {
        "todowrite": true,
        "todoread": true
      },
      "permission": {
        "bash": "allow",
        "edit": "allow"
      }
    },
    "junior-backend": {
      "description": "Invoke for simple backend tasks: CRUD, adding fields, unit tests, isolated bug fixes.",
      "model": "zai-coding-plan/glm-4.7",
      "mode": "subagent",
      "steps": 40,
      "tools": {
        "todowrite": true,
        "todoread": true
      },
      "permission": {
        "bash": "ask",
        "edit": "allow"
      }
    },
    "junior-frontend": {
      "description": "Invoke for simple frontend tasks: styling, small presentational components, component tests.",
      "model": "zai-coding-plan/glm-4.7",
      "mode": "subagent",
      "steps": 40,
      "tools": {
        "todowrite": true,
        "todoread": true
      },
      "permission": {
        "bash": "ask",
        "edit": "allow"
      }
    },
    "tester": {
      "description": "Invoke after implementation is complete. Writes and runs tests, reports bugs. Spawned in parallel per scope by leads.",
      "model": "alibaba-coding-plan/kimi-k2.5",
      "mode": "subagent",
      "steps": 60,
      "tools": {
        "todowrite": true,
        "todoread": true
      },
      "permission": {
        "bash": "allow",
        "edit": "allow"
      }
    },
    "code-reviewer": {
      "description": "Invoke after all tests pass. Reviews code quality, security, and standards. Never modifies code.",
      "model": "opencode/minimax-m2.5-free",
      "mode": "subagent",
      "steps": 40,
      "tools": {
        "todowrite": true,
        "todoread": true
      }
    },
    "debugger": {
      "description": "Invoke when root cause of a bug is unclear. Reads logs and stack traces. Analysis only.",
      "model": "alibaba-coding-plan/glm-5",
      "mode": "subagent",
      "steps": 60
    },
    "researcher": {
      "description": "Invoke to evaluate a technology or pattern. Produces comparison report with recommendation.",
      "model": "opencode/minimax-m2.5-free",
      "mode": "subagent",
      "steps": 40
    }
  },
  "mcp": {
   
  }
}